# ============================================================================
# wger-mcp configuration
# ============================================================================

# --- Upstream wger ----------------------------------------------------------
WGER_BASE_URL=https://wger.example.com
# DRF token: in wger, sign in → Settings → API → "Generate new API key".
WGER_API_TOKEN=CHANGE_ME

# --- Inbound auth strategy --------------------------------------------------
# One of: api_key | jwt | proxy_header | none
MCP_AUTH=api_key

# ---- Strategy: api_key -----------------------------------------------------
# Static shared secret(s). Accepted in either:
#   Authorization: Bearer <key>
#   <MCP_API_KEY_HEADER>: <key>           (default header: X-API-Key)
# Generate: openssl rand -hex 32
MCP_API_KEYS=
MCP_API_KEY_HEADER=X-API-Key

# ---- Strategy: jwt ---------------------------------------------------------
# Generic OIDC/OAuth2 Bearer JWT, validated against any provider's JWKS.
# Works with Keycloak, Authentik, Authelia (OIDC), Auth0, Okta, Cognito, dex, ...
#MCP_JWT_JWKS_URI=https://idp.example.com/.well-known/jwks.json
#MCP_JWT_ISSUER=https://idp.example.com
# Audience (optional). If set, the token's 'aud' claim must match.
#MCP_JWT_AUDIENCE=wger-mcp
# Comma-separated. Defaults to RS256.
#MCP_JWT_ALGORITHMS=RS256
# Which JWT claim names the user. Common values: sub, preferred_username, email.
#MCP_JWT_USERNAME_CLAIM=sub
# Optional allowlist. Empty = any authenticated user accepted.
#MCP_JWT_ALLOWED_USERS=
#MCP_JWT_JWKS_TTL_SECONDS=3600

# ---- Strategy: proxy_header ------------------------------------------------
# Trust an upstream reverse proxy (nginx, Caddy, Apache, Traefik) that has
# already authenticated the user (Authelia, Authentik, Keycloak via oauth2-proxy,
# LDAP, SAML, ...) and sets an identity header.
# Mirrors wger's own AUTH_PROXY_HEADER model.
#MCP_PROXY_USER_HEADER=X-Remote-User
#MCP_PROXY_EMAIL_HEADER=X-Remote-Email
# REQUIRED for safety: peer IP must be in this list (single IP or CIDR).
# Otherwise any HTTP client could forge the identity header.
#MCP_PROXY_TRUSTED_IPS=127.0.0.1,10.0.0.0/8
#MCP_PROXY_ALLOWED_USERS=

# --- Transport --------------------------------------------------------------
HOST=0.0.0.0
PORT=8765
# MCP endpoint mount path. Final URL: http(s)://host:port/mcp
MCP_PATH=/mcp

# DNS rebinding protection. Comma-separated Host header values you accept.
# Empty = disabled (e.g. local dev). Production: set to your public hostname.
ALLOWED_HOSTS=
